{
  "name": "autopilot-control-plane",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "description": "Typed governance contracts for the Autopilot control plane.",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "pdos:validate": "tsx product-design-os/scripts/validate-product-design-os.ts",
    "pdos:route": "tsx product-design-os/scripts/route-product-design-os.ts",
    "pdos:report": "tsx product-design-os/scripts/route-product-design-os.ts --format markdown",
    "pdos:score": "tsx product-design-os/scripts/score-product-design-os.ts",
    "pdos:visual-qa": "tsx product-design-os/scripts/visual-qa-product-design-os.ts",
    "pdos:reader:capture": "tsx product-design-os/scripts/capture-design-reader.ts",
    "pdos:reader:document": "tsx product-design-os/reader/document-reader-adapter.ts",
    "pdos:library:projects": "tsx product-design-os/scripts/update-project-library.ts",
    "mesh:generate": "tsx scripts/generate-decision-mesh.ts",
    "mesh:check": "tsx scripts/generate-decision-mesh.ts --check",
    "mcp:mesh": "tsx mcp/server.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "verify": "npm run mesh:check && npm run pdos:validate && npm run typecheck && npm run test && npm run build && npm run test:e2e"
  },
  "devDependencies": {
    "@playwright/test": "1.60.0",
    "@types/node": "25.9.1",
    "astro": "6.3.7",
    "tsx": "^4.22.3",
    "typescript": "6.0.3",
    "vitest": "4.1.7"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  }
}
