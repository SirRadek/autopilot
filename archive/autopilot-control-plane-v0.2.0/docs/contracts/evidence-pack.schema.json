{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://autopilot.local/contracts/evidence-pack.schema.json",
  "title": "Autopilot Evidence Pack",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "contract_version",
    "evidence_pack_id",
    "task_id",
    "project",
    "scope",
    "source_pointers",
    "checks",
    "artifacts",
    "risks",
    "impacts",
    "verification",
    "status"
  ],
  "properties": {
    "contract_version": {
      "type": "string",
      "pattern": "^v[0-9]+\\.[0-9]+$"
    },
    "evidence_pack_id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*$"
    },
    "task_id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*$"
    },
    "project": {
      "type": "object",
      "additionalProperties": false,
      "required": ["slug", "name"],
      "properties": {
        "slug": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]*$"
        },
        "name": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "scope": {
      "type": "object",
      "additionalProperties": false,
      "required": ["summary"],
      "properties": {
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "allowed_paths": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "forbidden_paths": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "non_goals": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        }
      }
    },
    "source_pointers": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "checks": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "status"],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "type": "string",
            "enum": ["pending", "passed", "failed", "skipped"]
          },
          "evidence": {
            "type": "string"
          }
        }
      },
      "minItems": 1
    },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "risks": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "impacts": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "verification": {
      "type": "object",
      "additionalProperties": false,
      "required": ["summary", "commands"],
      "properties": {
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "commands": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 1,
          "uniqueItems": true
        }
      }
    },
    "status": {
      "type": "string",
      "enum": ["draft", "ready", "needs_review", "blocked", "accepted"]
    }
  }
}
