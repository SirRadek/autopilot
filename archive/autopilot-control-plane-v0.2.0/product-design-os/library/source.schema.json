{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://autopilot.local/product-design-os/library/source.schema.json",
  "title": "Product Design Library Source",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "name",
    "category",
    "status",
    "source_url",
    "license",
    "commercial_use",
    "cost",
    "last_reviewed",
    "allowed_uses",
    "blocked_uses",
    "adoption_requirements"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*$"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "category": {
      "type": "string",
      "enum": [
        "illustration",
        "avatar",
        "3d_model",
        "texture",
        "hdri",
        "icon",
        "font",
        "svg_generator",
        "ui_template",
        "motion_reference",
        "tool",
        "license_reference",
        "inspiration_reference"
      ]
    },
    "status": {
      "type": "string",
      "enum": ["approved_source", "candidate_source", "inspiration_only", "blocked"]
    },
    "source_url": {
      "type": "string",
      "minLength": 1
    },
    "evidence_urls": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": []
    },
    "license": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "type", "url"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "type": {
          "type": "string",
          "enum": ["cc0", "mit", "isc", "apache-2.0", "bsd", "ofl", "cc-by", "custom", "unknown"]
        },
        "url": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "commercial_use": {
      "type": "string",
      "enum": ["allowed", "allowed_with_attribution", "inspiration_only", "unknown", "blocked"]
    },
    "cost": {
      "type": "string",
      "enum": ["free", "free_with_optional_paid", "unknown", "paid"]
    },
    "last_reviewed": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "allowed_uses": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "blocked_uses": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "adoption_requirements": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "notes": {
      "type": "string"
    }
  }
}
